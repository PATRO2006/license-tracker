# Copy to server/.env (or set in Render → Environment). All optional.

PORT=4000

# ---------- Database ----------
# If DATABASE_URL is set, the app uses PostgreSQL (data persists for free on Neon).
# If left blank, it uses a local SQLite file (set DATA_DIR or attach a disk to persist).
# Neon: create a free project, copy the connection string, paste it here.
DATABASE_URL=
# DATABASE_URL=postgresql://user:pass@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# SQLite data directory (only used when DATABASE_URL is blank)
# DATA_DIR=/data

# ---------- Email (Resend recommended) ----------
NOTIFY_EMAIL=support@safespacesinc.in       # admin recipient
SMTP_FROM=notifications@yourdomain.com       # must be a verified sender/domain in Resend

# Resend SMTP:
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=                                    # your Resend API key (re_...)
